import { getDb } from "../api/queries/connection";
import { users, categories, products } from "./schema";

async function seed() {
  const db = getDb();

  console.log("🌱 Starting database seed...\n");

  // ── 1. Clear existing data ──
  await db.delete(products);
  await db.delete(categories);
  await db.delete(users);
  console.log("  🗑️  Cleared existing data from all tables");

  // ── 2. Insert Users ──
  await db.insert(users).values([
    { fullName: "เภสัชกร แอดมิน", email: "admin@pharmacare.th", phone: "081-234-5678", role: "admin", tier: "INDIVIDUAL", verificationStatus: "APPROVED", isActive: 1 },
    { fullName: "สมชาย ใจดี", email: "somchai@email.com", phone: "089-876-5432", role: "customer", tier: "INDIVIDUAL", verificationStatus: "NONE", isActive: 1 },
    { fullName: "ร้านขายยา ใจการุณย์", email: "retail@pharmacy.co.th", phone: "02-123-4567", role: "customer", tier: "RETAIL", verificationStatus: "PENDING", licenseDocumentUrl: "mock-license-retail-pharmacy.jpg", isActive: 1 },
    { fullName: "คลินิกสมุนไพร วัลย์ลิกา", email: "clinic@wanlika.co.th", phone: "02-987-6543", role: "customer", tier: "CLINIC", verificationStatus: "APPROVED", licenseDocumentUrl: "mock-license-clinic-medical.jpg", isActive: 1 },
  ] as any);
