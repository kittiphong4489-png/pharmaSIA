  console.log("🔐 Test Accounts:");
  console.log(`   🛡️  Admin   : admin@pharmacare.th`);
  console.log(`   👤 Customer: somchai@email.com (INDIVIDUAL)`);
  console.log(`   🏪 Retail  : retail@pharmacy.co.th (PENDING)`);
