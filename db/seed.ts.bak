    { sku: "PARA-500-100", nameTh: "พาราเซตามอล 500 มก.", nameEn: "Paracetamol 500mg", shortDescriptionTh: "ยาบรรเทาปวด ลดไข้", shortDescriptionEn: "Pain reliever and fever reducer", descriptionTh: "พาราเซตามอล 500 มิลลิกรัม ใช้บรรเทาอาการปวดและลดไข้", descriptionEn: "Paracetamol 500mg tablets for pain relief and fever reduction.", pricesJson: JSON.stringify({ individual: 45, retail: 40, clinic: 36 }), price: 45, originalPrice: 55, stock: 500, unit: "box", image: "https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?w=400", visibleToJson: JSON.stringify(["INDIVIDUAL", "RETAIL", "CLINIC"]), categoryId: medCatId, isFeatured: 1, requiresPrescription: 0, status: "active", rating: 4.8, reviewCount: 245, soldCount: 1200, weightGrams: 50, legalCategory: "HOUSEHOLD_REMEDY", genericNameTh: "พาราเซตามอล", genericNameEn: "Paracetamol", barcode: "8851938012345" },
    { sku: "VITC-1000-30", nameTh: "วิตามินซี 1000 มก.", nameEn: "Vitamin C 1000mg", shortDescriptionTh: "วิตามินซีบำรุงภูมิคุ้มกัน", shortDescriptionEn: "Immune-boosting vitamin C supplement", descriptionTh: "วิตามินซี 1000 มิลลิกรัม ช่วยเสริมสร้างภูมิคุ้มกัน", descriptionEn: "Vitamin C 1000mg helps boost immune system.", pricesJson: JSON.stringify({ individual: 120, retail: 108, clinic: 96 }), price: 120, originalPrice: 150, stock: 300, unit: "bottle", image: "https://images.unsplash.com/photo-1550572017-edd951aa8f72?w=400", visibleToJson: JSON.stringify(["INDIVIDUAL", "RETAIL", "CLINIC"]), categoryId: vitCatId, isFeatured: 1, isNew: 1, requiresPrescription: 0, status: "active", rating: 4.6, reviewCount: 189, soldCount: 850, weightGrams: 80, legalCategory: "SUPPLEMENT", genericNameTh: "แอสคอร์บิกแอซิด", genericNameEn: "Ascorbic Acid", barcode: "8857208012345" },
    { sku: "AMOX-500-21", nameTh: "อะม็อกซิซิลลิน 500 มก.", nameEn: "Amoxicillin 500mg", shortDescriptionTh: "ยาปฏิชีวนะกลุ่มเพนิซิลลิน (ต้องใช้ใบสั่งยา)", shortDescriptionEn: "Penicillin-class antibiotic (prescription required)", descriptionTh: "อะม็อกซิซิลลิน 500 มิลลิกรัม ยาปฏิชีวนะกลุ่มเพนิซิลลิน **ต้องใช้ใบสั่งยาแพทย์**", descriptionEn: "Amoxicillin 500mg is a penicillin-class antibiotic. **Prescription required.**", pricesJson: JSON.stringify({ individual: 85, retail: 0, clinic: 68 }), price: 85, originalPrice: 100, stock: 200, unit: "capsule", image: "https://images.unsplash.com/photo-1471864190281-a93a3070b6de?w=400", visibleToJson: JSON.stringify(["INDIVIDUAL", "CLINIC"]), categoryId: medCatId, requiresPrescription: 1, status: "active", rating: 4.9, reviewCount: 78, soldCount: 420, weightGrams: 30, legalCategory: "DANGEROUS_DRUG", genericNameTh: "อะม็อกซิซิลลิน", genericNameEn: "Amoxicillin", barcode: "8850999001234" },
