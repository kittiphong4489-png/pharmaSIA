    { sku: "THERM-DIG-01", nameTh: "เทอร์โมมิเตอร์ดิจิตอล", nameEn: "Digital Thermometer", shortDescriptionTh: "วัดอุณหภูมิร่างกายแบบดิจิตอล", shortDescriptionEn: "Digital body temperature thermometer", descriptionTh: "เทอร์โมมิเตอร์ดิจิตอลวัดอุณหภูมิร่างกาย แสดงผลแบบตัวเลขชัดเจน", descriptionEn: "Digital thermometer for body temperature measurement.", pricesJson: JSON.stringify({ individual: 195, retail: 175, clinic: 156 }), price: 195, originalPrice: 250, stock: 150, unit: "piece", image: "https://images.unsplash.com/photo-1583947581924-860bda6a26df?w=400", visibleToJson: JSON.stringify(["INDIVIDUAL", "RETAIL", "CLINIC"]), categoryId: devCatId, isFeatured: 1, requiresPrescription: 0, status: "active", rating: 4.7, reviewCount: 203, soldCount: 560, weightGrams: 120, legalCategory: "HOUSEHOLD_REMEDY", genericNameTh: "เทอร์โมมิเตอร์ดิจิตอล", genericNameEn: "Digital Thermometer", barcode: "8850999012345" },
    { sku: "MASK-3PLY-50", nameTh: "หน้ากากอนามัย 3 ชั้น (50 ชิ้น)", nameEn: "3-Ply Surgical Mask (50 pcs)", shortDescriptionTh: "หน้ากากอนามัย 3 ชั้น ป้องกันฝุ่นและเชื้อโรค", shortDescriptionEn: "3-ply surgical mask for dust and germ protection", descriptionTh: "หน้ากากอนามัย 3 ชั้น คุณภาพทางการแพทย์", descriptionEn: "Medical-grade 3-ply surgical mask.", pricesJson: JSON.stringify({ individual: 89, retail: 75, clinic: 65 }), price: 89, originalPrice: 120, stock: 1000, unit: "pack", image: "https://images.unsplash.com/photo-1584634731339-252c581abfc5?w=400", visibleToJson: JSON.stringify(["INDIVIDUAL", "RETAIL", "CLINIC"]), categoryId: devCatId, isNew: 1, requiresPrescription: 0, status: "active", rating: 4.4, reviewCount: 312, soldCount: 2100, weightGrams: 200, legalCategory: "HOUSEHOLD_REMEDY", genericNameTh: "หน้ากากอนามัย 3 ชั้น", genericNameEn: "3-Ply Surgical Mask", barcode: "8850366123456" },
  ] as any);
  const seededProducts = await db.select().from(products);
  console.log(`  💊 Inserted ${seededProducts.length} products`);
  seededProducts.forEach((p: any) => {
    const vis = JSON.parse(p.visibleToJson);
    const hideRetail = !vis.includes("RETAIL") ? "🚫RETAIL" : "";
    const rxBadge = p.requiresPrescription ? "📋Rx" : "";
    console.log(`      • ${p.nameTh} ฿${p.price} ${hideRetail} ${rxBadge}`.trim());
  });

  // ── Summary ──
