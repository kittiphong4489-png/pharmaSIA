  await db.insert(categories).values([
    { nameTh: "ยารักษาโรค", nameEn: "Medicines", slug: "medicines", descriptionTh: "ยาสำหรับรักษาโรคต่างๆ", descriptionEn: "Medicines for various conditions", icon: "pill", color: "#ef4444", sortOrder: 1, isActive: 1 },
    { nameTh: "วิตามินและอาหารเสริม", nameEn: "Vitamins & Supplements", slug: "vitamins-supplements", descriptionTh: "วิตามินและอาหารเสริมบำรุงร่างกาย", descriptionEn: "Vitamins and dietary supplements", icon: "heart", color: "#22c55e", sortOrder: 2, isActive: 1 },
    { nameTh: "อุปกรณ์การแพทย์", nameEn: "Medical Devices", slug: "medical-devices", descriptionTh: "อุปกรณ์ทางการแพทย์สำหรับใช้ในบ้าน", descriptionEn: "Home medical devices", icon: "stethoscope", color: "#3b82f6", sortOrder: 3, isActive: 1 },
    { nameTh: "ผลิตภัณฑ์ดูแลสุขภาพ", nameEn: "Health Care", slug: "health-care", descriptionTh: "ผลิตภัณฑ์ดูแลสุขภาพและความงาม", descriptionEn: "Health and beauty care products", icon: "sparkles", color: "#a855f7", sortOrder: 4, isActive: 1 },
  ] as any);
  const seededCategories = await db.select().from(categories);
  console.log(`  📁 Inserted ${seededCategories.length} categories`);

  // ── 4. Insert Products with B2B pricing ──
  const medCatId = seededCategories[0].id;
  const vitCatId = seededCategories[1].id;
  const devCatId = seededCategories[2].id;

